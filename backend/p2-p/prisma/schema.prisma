generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  pending
  funded
  completed
  cancelled
}

enum OfferType {
  buy
  sell
}

enum OfferStatus {
  active
  closed
}

enum EscrowStatus {
  locked
  released
  disputed
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  hashedPassword String
  balance        Decimal  @default(0)
  walletAddress  String?  @unique
  username       String?
  createdAt      DateTime @default(now())

  buyTrades  Trade[] @relation("BuyerTrades")
  sellTrades Trade[] @relation("SellerTrades")
  offers     Offer[]
}

model Offer {
  id        String      @id @default(uuid())
  userId    String
  type      OfferType
  asset     String
  price     Decimal
  status    OfferStatus @default(active)
  createdAt DateTime    @default(now())

  user   User    @relation(fields: [userId], references: [id])
  trades Trade[]
}

model Trade {
  id             String      @id @default(uuid())
  buyerId        String
  sellerId       String
  offerId        String
  amount         Decimal
  idempotencyKey String      @unique
  status         TradeStatus @default(pending)
  createdAt      DateTime    @default(now())

  buyer  User    @relation("BuyerTrades", fields: [buyerId], references: [id])
  seller User    @relation("SellerTrades", fields: [sellerId], references: [id])
  offer  Offer   @relation(fields: [offerId], references: [id])
  escrow Escrow?
}

model Escrow {
  id              String       @id @default(uuid())
  tradeId         String       @unique
  contractAddress String?
  status          EscrowStatus @default(locked)
  createdAt       DateTime     @default(now())

  trade Trade @relation(fields: [tradeId], references: [id])
}
