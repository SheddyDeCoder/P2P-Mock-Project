// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int      @id @default(autoincrement())
  username       String
  email          String   @unique
  hashedPassword String
  walletAddress  String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  sellerOrders Order[]   @relation("SellerOrders")
  disputes     Dispute[]

  @@map("users")
}

model Order {
  id       Int  @id @default(autoincrement())
  sellerId Int
  seller   User @relation("SellerOrders", fields: [sellerId], references: [id])

  type          OrderType // BUY or SELL
  asset         String // e.g., "BTC", "ETH"
  fiatCurrency  String // e.g., "USD", "EUR"
  amount        Float // Amount of crypto
  price         Float // Price per unit in fiat
  minAmount     Float // Minimum trade amount
  maxAmount     Float // Maximum trade amount
  paymentMethod String // e.g., "BANK_TRANSFER", "CARD"

  status    OrderStatus @default(ACTIVE)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  trades Trade[]

  @@index([sellerId])
  @@index([status])
  @@index([type, asset, fiatCurrency])
}

model Trade {
  id             Int    @id @default(autoincrement())
  idempotencyKey String @unique

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  amount        Float
  fiatcurrency  String
  totalPrice    Float // amount * price
  fiatCurrency  String
  paymentMethod String

  buyerWalletAddress String

  //escrow
  status TradeStatus @default(PENDING)

  // Timestamps for state transitions
  pendingAt   DateTime  @default(now())
  lockedAt    DateTime?
  completedAt DateTime?
  disputedAt  DateTime?
  cancelledAt DateTime?

  // Timeout handling
  timeoutAt     DateTime? // When current state expires
  timeoutAction String? // Action to take on timeout (RELEASE, REFUND, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  disputes Dispute[]

  @@unique([orderId, buyerWalletAddress]) // Prevent duplicate trades on same order
  @@index([buyerWalletAddress])
  @@index([status])
  @@index([timeoutAt])
}

// Dispute management
model Dispute {
  id         Int   @id @default(autoincrement())
  tradeId    Int
  trade      Trade @relation(fields: [tradeId], references: [id])
  raisedById Int
  raisedBy   User  @relation(fields: [raisedById], references: [id])

  reason     String
  evidence   String[] // URLs to evidence files
  status     DisputeStatus @default(OPEN) // OPEN, UNDER_REVIEW, RESOLVED
  resolution String? // Resolution notes

  resolvedAt   DateTime?
  resolvedById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tradeId])
  @@index([status])
}

// Idempotency tracking
model IdempotencyRecord {
  id        String   @id @default(cuid())
  key       String   @unique
  response  Json // Cached response
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([key])
  @@index([expiresAt])
}

// Enums
enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  ACTIVE
  FAILLED
  CANCELLED
  EXPIRED
}

enum TradeStatus {
  PENDING // Trade created, awaiting payment
  LOCKED // Funds locked in escrow (if applicable)
  COMPLETED // Trade completed successfully
  DISPUTED // Under dispute
  CANCELLED // Cancelled before completion
  EXPIRED // Timeout reached
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}
