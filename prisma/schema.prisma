generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model escrow {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trade_id         String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_address String?
  escrow_status    String?   @default("locked | released | disputed")
  created_at       DateTime? @default(dbgenerated("'2026-02-23 14:44:57.989753'::timestamp without time zone")) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model offers {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  offer_type String?   @default("buy | sell")
  asset_type String?
  price      Decimal?  @db.Decimal
  status     String?   @default("active | closed")
  created_at DateTime? @default(dbgenerated("'2026-02-23 14:37:46.604936'::timestamp without time zone")) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model trades {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyer_id   String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id  String?   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount     Decimal?  @db.Decimal
  status     String?   @default("locked | released | disputed")
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id             BigInt    @id @default(autoincrement())
  wallet_address String
  username       String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}
